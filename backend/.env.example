# Async-драйвер (приложение работает на async SQLAlchemy). Локально можно
# sqlite+aiosqlite:///./cv_tailor.db
DATABASE_URL=postgresql+asyncpg://cv_tailor:cv_tailor@postgres:5432/cv_tailor
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=super-secret-key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Токены
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ── Согласие / админ
CONSENT_VERSION=2026-06-24
BOOTSTRAP_ADMIN_EMAIL=

# ── Внешние URL (для OAuth redirect и возврата во фронт)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ── Яндекс SmartCaptcha (серверный ключ; пусто = проверка пропускается)
SMARTCAPTCHA_SERVER_KEY=

# ── OAuth провайдеры
# Яндекс: https://oauth.yandex.ru/  ·  VK: https://id.vk.com/about/business
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ── SMTP для отправки кода подтверждения (пусто = код печатается в консоль)
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cv-tailor.local

# ── Эквайринг Т-Банк (оплата PRO-подписки; пусто = оплата отключена)
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2/
TINKOFF_TAXATION=usn_income
TINKOFF_VAT=none

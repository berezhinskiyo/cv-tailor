# ─────────────────────────────────────────────────────────────────────────────
# TEST-окружение cvtailor — файл кладётся на сервер как /opt/cvtailor-test/.env
# НЕ коммитить с реальными значениями. Деплой (git reset --hard) его НЕ трогает
# (в .gitignore). Docker compose берёт эти значения для интерполяции ${VAR}.
# ─────────────────────────────────────────────────────────────────────────────

# Изоляция стека и порт для общего прокси
COMPOSE_PROJECT_NAME=cvtailor-test
WEB_PORT=28080

# Секреты инфраструктуры (сгенерировать СВОИ, отличные от prod)
POSTGRES_PASSWORD=CHANGE_ME_test_db_password
JWT_SECRET_KEY=CHANGE_ME_test_jwt_secret

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Внешние URL (через общий прокси, https)
FRONTEND_URL=https://cvtailor.test.vniknu.ru
BACKEND_URL=https://cvtailor.test.vniknu.ru

# Согласие / бутстрап-админ
CONSENT_VERSION=2026-06-24
BOOTSTRAP_ADMIN_EMAIL=admin@cvtailor.ru

# Яндекс SmartCaptcha
SMARTCAPTCHA_SERVER_KEY=
VITE_SMARTCAPTCHA_SITEKEY=

# OAuth (redirect URI test-домена должен быть добавлен в приложениях Яндекс/VK!)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# SMTP (пусто = код в логи backend)
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cvtailor.ru

# Эквайринг Т-Банк — на TEST используем ДЕМО-терминал (креды из ЛК Т-Банка,
# раздел «Демо-магазин»; в git НЕ коммитим, вписываем прямо в /opt/cvtailor-test/.env)
TINKOFF_TERMINAL_KEY=<DEMO_TERMINAL_KEY>
TINKOFF_PASSWORD=<DEMO_PASSWORD>
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2/
TINKOFF_TAXATION=usn_income
TINKOFF_VAT=none

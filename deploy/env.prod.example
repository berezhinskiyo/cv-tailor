# ─────────────────────────────────────────────────────────────────────────────
# PROD-окружение cvtailor — файл кладётся на сервер как /opt/cvtailor-prod/.env
# НЕ коммитить с реальными значениями. Деплой (git reset --hard) его НЕ трогает
# (в .gitignore). Docker compose берёт эти значения для интерполяции ${VAR}.
# ─────────────────────────────────────────────────────────────────────────────

# Изоляция стека и порт для общего edge
COMPOSE_PROJECT_NAME=cvtailor-prod
WEB_PORT=18080

# Доступ к ОБЩЕМУ PostgreSQL (стек shared-postgres). База/роль этого окружения.
# DB_PASSWORD должен совпадать с CVTAILOR_PROD_DB_PASSWORD в /opt/shared-postgres/.env
DB_USER=cvtailor_prod
DB_NAME=cvtailor_prod
DB_PASSWORD=CHANGE_ME_cvtailor_prod

# JWT (свой секрет)
JWT_SECRET_KEY=CHANGE_ME_prod_jwt_secret

# LLM — OpenAI-совместимый API (OpenRouter/polza.ai/OpenAI).
# OPENAI_BASE_URL пусто = официальный OpenAI. Для OpenRouter модель с префиксом провайдера.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# Внешние URL (через общий прокси, https)
FRONTEND_URL=https://cvtailor.vniknu.ru
BACKEND_URL=https://cvtailor.vniknu.ru

# Согласие / бутстрап-админ
CONSENT_VERSION=2026-06-24
BOOTSTRAP_ADMIN_EMAIL=admin@cvtailor.ru

# Яндекс SmartCaptcha
SMARTCAPTCHA_SERVER_KEY=
VITE_SMARTCAPTCHA_SITEKEY=

# OAuth (redirect URI prod-домена должен быть добавлен в приложениях Яндекс/VK!)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Email через Yandex Postbox (HTTP API, боевой). SMTP_FROM = адрес отправителя.
EMAIL_HTTP_ENDPOINT=https://postbox.cloud.yandex.net
EMAIL_HTTP_KEY_ID=
EMAIL_HTTP_SECRET=
SMTP_FROM=noreply@cvtailor.ru

# Эквайринг Т-Банк — БОЕВЫЕ креды из ЛК Т-Банка (НЕ демо!)
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2/
TINKOFF_TAXATION=usn_income
TINKOFF_VAT=none
